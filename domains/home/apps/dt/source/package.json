{
  "name": "dt",
  "version": "1.0.0",
  "description": "DataX time tracker",
  "type": "module",
  "bin": {
    "dt": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "esbuild src/cli/index.ts --bundle --platform=node --format=esm --outdir=dist --packages=external --banner:js='#!/usr/bin/env node' --splitting --outbase=src",
    "build:all": "node build.mjs",
    "dev": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "@iarna/toml": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^13.0.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "pdfkit": "^0.16.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/pdfkit": "^0.13.0",
    "@types/react": "^18.3.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
