{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 38,
  "tags": ["hwc", "frigate", "cameras"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Cameras",
  "uid": "cameras",
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Frigate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [ { "refId": "A", "expr": "count(frigate_camera_fps)", "instant": true } ],
      "fieldConfig": { "defaults": { "decimals": 0, "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "mappings": [ { "type": "range", "options": { "from": 0, "to": 0, "result": { "text": "DOWN", "color": "red" } } } ] }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value_and_name", "justifyMode": "center" }
    },
    {
      "id": 2, "type": "stat", "title": "Cameras online",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "targets": [ { "refId": "A", "expr": "count(frigate_camera_fps > 0)", "instant": true }, { "refId": "B", "expr": "count(frigate_camera_fps)", "instant": true } ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 3, "type": "stat", "title": "Detection total FPS",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "targets": [ { "refId": "A", "expr": "frigate_detection_total_fps", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 4, "type": "stat", "title": "Inference speed (onnx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "targets": [ { "refId": "A", "expr": "frigate_detector_inference_speed_seconds * 1000", "legendFormat": "{{name}}", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 5, "type": "stat", "title": "Frigate uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "targets": [ { "refId": "A", "expr": "frigate_service_uptime_seconds", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 6, "type": "timeseries", "title": "Camera FPS (capture)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [ { "refId": "A", "expr": "frigate_camera_fps", "legendFormat": "{{camera_name}}" } ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "min": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "min"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Detection FPS",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [ { "refId": "A", "expr": "frigate_detection_fps", "legendFormat": "{{camera_name}}" } ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "min": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 8, "type": "bargauge", "title": "CPU by camera (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [ { "refId": "A", "expr": "sum by (name) (frigate_cpu_usage_percent{type=\"Camera\"})", "legendFormat": "{{name}}", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "color": { "mode": "continuous-GrYlRd" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "valueMode": "text", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 9, "type": "timeseries", "title": "GPU utilisation (%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "frigate_gpu_usage_percent", "legendFormat": "GPU {{gpu_name}}" },
        { "refId": "B", "expr": "frigate_gpu_mem_usage_percent", "legendFormat": "GPU mem {{gpu_name}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "min": 0, "max": 100, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 10, "type": "timeseries", "title": "Detector inference speed (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "targets": [ { "refId": "A", "expr": "frigate_detector_inference_speed_seconds * 1000", "legendFormat": "{{name}}" } ],
      "fieldConfig": { "defaults": { "unit": "ms", "decimals": 1, "min": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "single" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Camera stream bandwidth",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [ { "refId": "A", "expr": "frigate_bandwidth_usages_kBps * 1024", "legendFormat": "{{camera_name}}" } ],
      "fieldConfig": { "defaults": { "unit": "Bps", "decimals": 0, "min": 0, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 12, "type": "bargauge", "title": "Surveillance storage used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [ { "refId": "A", "expr": "100 * frigate_storage_used_bytes / (frigate_storage_used_bytes + frigate_storage_free_bytes)", "legendFormat": "{{storage}}", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 92 } ] } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "valueMode": "text", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
