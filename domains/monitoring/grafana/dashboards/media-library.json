{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 38,
  "tags": ["hwc", "media", "arr"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "browser",
  "title": "Media Library",
  "uid": "media-library",
  "refresh": "1m",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Movies",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [ { "refId": "A", "expr": "sum(radarr_movie_total)", "instant": true } ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 2, "type": "stat", "title": "Series",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [ { "refId": "A", "expr": "sum(sonarr_series_total)", "instant": true } ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 3, "type": "stat", "title": "Episodes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [ { "refId": "A", "expr": "sum(sonarr_episode_total)", "instant": true } ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 4, "type": "stat", "title": "Artists",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [ { "refId": "A", "expr": "sum(lidarr_artists_total)", "instant": true } ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 5, "type": "stat", "title": "Library size",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [ { "refId": "A", "expr": "sum({__name__=~\"radarr_movie_filesize_total|sonarr_series_filesize_bytes|lidarr_artists_filesize_bytes\"})", "instant": true } ],
      "fieldConfig": { "defaults": { "unit": "bytes", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "text" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 6, "type": "stat", "title": "Health issues",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [ { "refId": "A", "expr": "sum({__name__=~\".+_system_health_issues\"}) or vector(0)", "instant": true } ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "value", "justifyMode": "center" }
    },
    {
      "id": 7, "type": "bargauge", "title": "Missing / wanted",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(radarr_movie_missing_total)", "legendFormat": "movies missing", "instant": true },
        { "refId": "B", "expr": "sum(sonarr_episode_missing_total)", "legendFormat": "episodes missing", "instant": true },
        { "refId": "C", "expr": "sum(lidarr_albums_missing_total)", "legendFormat": "albums missing", "instant": true }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 } ] } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8, "type": "bargauge", "title": "Download queues",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [
        { "refId": "A", "expr": "sum(radarr_queue_total)", "legendFormat": "radarr", "instant": true },
        { "refId": "B", "expr": "sum(sonarr_queue_total) or vector(0)", "legendFormat": "sonarr", "instant": true },
        { "refId": "C", "expr": "sum(lidarr_queue_total) or vector(0)", "legendFormat": "lidarr", "instant": true }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "color": { "mode": "continuous-GrYlRd" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 9, "type": "bargauge", "title": "Root folder free space",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [ { "refId": "A", "expr": "max by (__name__) ({__name__=~\"(radarr|sonarr|lidarr)_rootfolder_freespace_bytes\"})", "legendFormat": "{{__name__}}", "instant": true } ],
      "fieldConfig": {
        "defaults": { "unit": "bytes", "decimals": 0, "min": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 107374182400 }, { "color": "green", "value": 536870912000 } ] } },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "basic", "valueMode": "color", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 10, "type": "timeseries", "title": "Library growth",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "refId": "A", "expr": "sum(radarr_movie_total)", "legendFormat": "movies" },
        { "refId": "B", "expr": "sum(sonarr_episode_total)", "legendFormat": "episodes" },
        { "refId": "C", "expr": "sum(lidarr_songs_total)", "legendFormat": "songs" }
      ],
      "fieldConfig": { "defaults": { "decimals": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 8, "showPoints": "never", "gradientMode": "opacity" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "id": 11, "type": "timeseries", "title": "Prowlarr indexer response time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 12 },
      "targets": [ { "refId": "A", "expr": "prowlarr_indexer_average_response_time_ms", "legendFormat": "{{indexer}}" } ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    }
  ]
}
