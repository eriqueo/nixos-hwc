{# Testimonials — editorial pull-quote when no service filter, grid otherwise #}

{% if show_reviews_grid or filter_service %}
{# Service-page version: filtered grid #}
<section class="section section-testimonials section-alt animate-in" data-section="testimonials">
  <div class="container-wide">
    <div class="section-header">
      <span class="eyebrow">{{ reviews_eyebrow if reviews_eyebrow else "CLIENT VOICES" }}</span>
      <h2>{{ reviews_heading if reviews_heading else (testimonials_heading if testimonials_heading else "What our clients say.") }}</h2>
      <hr>
    </div>
    <div class="testimonial-grid" itemscope itemtype="https://schema.org/LocalBusiness">
      <meta itemprop="name" content="{{ site.name }}">
      {% for review in testimonials %}
        {% if show_reviews_grid or review.service == filter_service %}
        <div class="card testimonial-card animate-in" itemprop="review" itemscope itemtype="https://schema.org/Review">
          <div class="testimonial-rating" aria-label="{{ review.rating }} out of 5 stars" itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating">
            <meta itemprop="ratingValue" content="{{ review.rating }}">
            <meta itemprop="bestRating" content="5">
            {% for i in range(0, review.rating) %}&#9733;{% endfor %}
          </div>
          <blockquote class="testimonial-text" itemprop="reviewBody">{{ review.text | truncate(150) }} <a href="/reviews/" class="review-more">Read more →</a></blockquote>
          <div class="testimonial-author" itemprop="author" itemscope itemtype="https://schema.org/Person">
            <strong itemprop="name">{{ review.name }}</strong>
            <span>{{ review.location }}</span>
          </div>
          <div class="testimonial-source">via {{ review.source }}</div>
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% else %}
{# Home/general version: editorial single pull-quote (first testimonial) #}
{% set t = testimonials[0] %}
<section class="section section-alt animate-in" data-section="testimonial">
  <div class="container-wide">
    <div class="ed-quote" itemprop="review" itemscope itemtype="https://schema.org/Review">
      <meta itemprop="reviewRating" itemscope itemtype="https://schema.org/Rating" content="">
      <meta itemprop="ratingValue" content="{{ t.rating }}">
      <hr>
      <blockquote class="ed-quote__body" itemprop="reviewBody">{{ t.text }}</blockquote>
      <div class="ed-quote__attr">
        <span class="ed-quote__name" itemprop="author">{{ t.name }} &mdash; {{ t.location }}</span>
        <span class="ed-quote__sep">·</span>
        <span class="ed-quote__meta">VERIFIED VIA {{ t.source | upper }}</span>
      </div>
    </div>
  </div>
</section>
{% endif %}
