{# Services grid — editorial 4-up #}
<section class="section section-services animate-in" data-section="services">
  <div class="container-wide">
    <div class="section-header">
      <span class="eyebrow">{{ services_eyebrow if services_eyebrow else "WHAT WE DO" }}</span>
      <h2>{{ services_heading if services_heading else "Four categories. Every job scoped and priced up front." }}</h2>
      <hr>
    </div>
    <div class="services-grid">
      {% for service in services %}
      <a href="{{ service.url }}" class="card service-card animate-in">
        <div class="service-icon" aria-hidden="true">
          {% if service.icon == "bath" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6H20M4 6h1M4 12h16M4 18h16M8 6v6M16 6v6"/></svg>
          {% elif service.icon == "layers" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          {% elif service.icon == "home" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          {% elif service.icon == "grid" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          {% elif service.icon == "ruler" %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21.3 15.3 15.3 21.3a1 1 0 0 1-1.4 0L2.7 10.1a1 1 0 0 1 0-1.4l6-6a1 1 0 0 1 1.4 0l11.2 11.2a1 1 0 0 1 0 1.4Z"/><path d="m14.5 12.5-2 2"/><path d="m11.5 9.5-2 2"/><path d="m8.5 6.5-2 2"/></svg>
          {% else %}
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
          {% endif %}
        </div>
        <h3>{{ service.name }}</h3>
        <p>{{ service.tagline }}</p>
        <span class="card-link">
          Learn more
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
