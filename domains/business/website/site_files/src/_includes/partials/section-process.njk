<section class="section section-alt animate-in" data-section="process">
  <div class="container-wide">
    <div class="section-header">
      <span class="eyebrow">{{ process_eyebrow if process_eyebrow else "OUR PROCESS" }}</span>
      <h2>{{ process_heading if process_heading else "This is how we do it." }}</h2>
      <hr>
      {% if process_intro %}<p>{{ process_intro }}</p>{% endif %}
    </div>
    <div class="process-grid">
        {% if process_steps %}
          {% for step in process_steps %}
          <div class="process-step">
            <div class="step-number">{{ "%02d" | format(loop.index) }}</div>
            <div>
              <h3>{{ step.title }}</h3>
              <p>{{ step.text }}</p>
            </div>
          </div>
          {% endfor %}
        {% else %}
          <div class="process-step">
            <div class="step-number">01</div>
            <div>
              <h3>Clarity through Communication</h3>
              <p>The last thing a remodel needs is surprises. We talk through your goals upfront to define the full scope — so changes during construction stay rare and expectations stay clear.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-number">02</div>
            <div>
              <h3>Design Before Demo</h3>
              <p>Where it makes sense, we build a 3D rendering of your space so you can see tile patterns, fixture placement, and layout before construction starts. Changes on screen cost nothing.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-number">03</div>
            <div>
              <h3>Numbers Before Nails</h3>
              <p>Combining a project's scope and design allows everyone involved to be on the same page before the dust flies.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-number">04</div>
            <div>
              <h3>Expert Execution</h3>
              <p>We utilize <a href="https://www.jobtread.com/who-we-serve/homeowners">JobTread Software</a> to manage our projects. This gives both contractor and client a single space to speak, share, and see the work being done.</p>
            </div>
          </div>
        {% endif %}
    </div>
  </div>
</section>
