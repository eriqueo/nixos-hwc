{# ─────────────────────────────────────────────────────────────────────
   Heartwood Craft — Contact Form (JT Web Form Embed + Attribution)

   This replaces the old n8n-webhook form. JT's web-form.js handles
   submission directly — creates customer + contact + job in JobTread.

   The contactCreated webhook in JT fires to Quo for SMS auto-response.
   GA4 form_submit event fires on successful submission.
   Hidden Lead Source field is populated from UTM params / referrer.

   JT Web Form Key: 22SVpdtTrvNNMLqKwpYhZM3PVYfCyZXax8

   JT Custom Field IDs:
     contact.name           → Contact name (built-in)
     contact.custom.22Nm3uGRBrPX → Email
     contact.custom.22Nm3uGb7WT2 → Phone
     account.custom.22PUGvBnXeYs → Lead Source (option field)
     account.custom.22Nnj9KMKEPC → Project Type (option field)
     account.custom.22NnjWw3NTGc → Appointment date
     account.custom.22NnjXZhpFXn → Time Choice (option field)
   ───────────────────────────────────────────────────────────────────── #}

<section class="section section-form" id="contact-form">
  <div class="container container-narrow">
    <h2>Tell Us About Your Project</h2>
    <p class="section-subtitle">Share a few details and we'll reach out to discuss next steps.</p>

    {# ── JT Web Form ── #}
    <form 
      class="jtwf hwc-form" 
      id="hwc-contact-form"
      data-jobtread-web-form="true" 
      data-key="22SVpdtTrvNNMLqKwpYhZM3PVYfCyZXax8" 
      data-success-message="Thanks — we'll be in touch soon to discuss your project."
      data-success-url="https://iheartwoodcraft.com/our-work"
    >

      {# ── Required: Name ── #}
      <div class="form-field">
        <label for="jt-name">Name <span class="required">*</span></label>
        <input 
          type="text" 
          id="jt-name" 
          name="contact.name" 
          placeholder="Your name" 
          required 
        />
      </div>

      {# ── Required: Phone ── #}
      <div class="form-field">
        <label for="jt-phone">Phone <span class="required">*</span></label>
        <input 
          type="tel" 
          id="jt-phone" 
          name="contact.custom.22Nm3uGb7WT2" 
          placeholder="(406) 555-1234" 
          required 
        />
      </div>

      {# ── Required: Email ── #}
      <div class="form-field">
        <label for="jt-email">Email <span class="required">*</span></label>
        <input 
          type="email" 
          id="jt-email" 
          name="contact.custom.22Nm3uGRBrPX" 
          placeholder="you@example.com" 
          required 
        />
      </div>

      {# ── Required: Project Type ── #}
      <div class="form-field">
        <label for="jt-project">What kind of project? <span class="required">*</span></label>
        <select id="jt-project" name="account.custom.22Nnj9KMKEPC" required>
          <option value="">Select one...</option>
          <option value="Bathroom Remodel">Bathroom remodel</option>
          <option value="Deck">Deck or outdoor living</option>
          <option value="Custom">Custom carpentry</option>
          <option value="Interior">Interior remodel</option>
          <option value="Exterior">Exterior work</option>
          <option value="Addition">Addition</option>
          <option value="Fence">Fence</option>
        </select>
      </div>

      {# ── Optional: Best day to call ── #}
      <div class="form-field">
        <label for="jt-day">Best day to call <span class="optional">(optional)</span></label>
        <input 
          type="date" 
          id="jt-day" 
          name="account.custom.22NnjWw3NTGc" 
        />
      </div>

      {# ── Optional: Time preference ── #}
      <div class="form-field">
        <label>Best time to call <span class="optional">(optional)</span></label>
        <div class="checkbox-group">
          <label class="checkbox-label">
            <input type="checkbox" name="account.custom.22NnjXZhpFXn" value="8am-10am" />
            <span>8–10 am</span>
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="account.custom.22NnjXZhpFXn" value="10am-12pm" />
            <span>10 am–12 pm</span>
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="account.custom.22NnjXZhpFXn" value="12pm-2pm" />
            <span>12–2 pm</span>
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="account.custom.22NnjXZhpFXn" value="2pm-4pm" />
            <span>2–4 pm</span>
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="account.custom.22NnjXZhpFXn" value="4pm-530pm" />
            <span>4–5:30 pm</span>
          </label>
        </div>
      </div>

      {# ── Required: How did you hear about us? (Lead Source) ── #}
      <div class="form-field">
        <label for="jt-source">How did you hear about us? <span class="required">*</span></label>
        <select id="jt-source" name="account.custom.22PUGvBnXeYs" required>
          <option value="">Select one...</option>
          <option value="Google Local Service">Google ad</option>
          <option value="Google General">Google search</option>
          <option value="Word of Mouth">Friend or neighbor</option>
          <option value="Facebook">Facebook</option>
          <option value="Instagram">Instagram</option>
          <option value="Short Term Rental">Short-term rental / property manager</option>
          <option value="Chamber">Chamber of Commerce</option>
          <option value="Website">Found your website</option>
          <option value="Repeat">I'm a past customer</option>
          <option value="Other">Other</option>
        </select>
      </div>

      {# ── Hidden: satisfy JT's required location.address validation ── #}
      <input type="hidden" name="location.address" value="Bozeman, MT" />

      {# ── Honeypot: hidden field that bots fill, humans never see ── #}
      <div class="form-field hp-wrap" aria-hidden="true">
        <label for="hp-website">Website</label>
        <input type="text" id="hp-website" name="website" tabindex="-1" autocomplete="off" />
      </div>

      {# ── Submit ── #}
      <button type="submit" class="btn btn-primary btn-full" data-submit-button="true">
        Start the Conversation
      </button>

    </form>

    <noscript>
      <p>To request an estimate, call <a href="{{ site.phoneLink }}">{{ site.phone }}</a> or email <a href="mailto:{{ site.email }}">{{ site.email }}</a>.</p>
    </noscript>
  </div>
</section>

{# ── JT Web Form Script ── #}
<script async src="https://app.jobtread.com/web-form.js"></script>

{# ── Attribution Bridge + dataLayer Event ── #}
<script>
(function() {
  'use strict';

  var form = document.getElementById('hwc-contact-form');
  if (!form) return;

  // ── Auto-select Lead Source from UTM if user hasn't chosen ──
  function autoSelectSource() {
    var sourceSelect = document.getElementById('jt-source');
    if (!sourceSelect || sourceSelect.value) return;

    try {
      var gclid = sessionStorage.getItem('hwc_gclid');
      var utm_source = sessionStorage.getItem('hwc_utm_source') || '';
      var utm_medium = sessionStorage.getItem('hwc_utm_medium') || '';

      if (gclid) {
        sourceSelect.value = 'Google Local Service';
      } else if (utm_source === 'google' && utm_medium === 'cpc') {
        sourceSelect.value = 'Google Local Service';
      } else if (utm_source === 'google') {
        sourceSelect.value = 'Google General';
      } else if (utm_source === 'facebook' || utm_source === 'fb') {
        sourceSelect.value = 'Facebook';
      } else if (utm_source === 'instagram' || utm_source === 'ig') {
        sourceSelect.value = 'Instagram';
      }
    } catch(e) {}
  }

  // ── Honeypot check on submit ──
  form.addEventListener('submit', function(e) {
    var hp = document.getElementById('hp-website');
    if (hp && hp.value) {
      e.preventDefault();
      form.hidden = true;
      var msg = document.createElement('p');
      msg.className = 'section-subtitle';
      msg.textContent = 'Thanks — we\'ll be in touch soon to discuss your project.';
      form.parentElement.appendChild(msg);
      return;
    }
    // Mark as submitted for beforeunload handler
    form.dataset.submitted = 'true';
  });

  // ── Fire lead_form_submit AFTER JT confirms success ──
  // Watch for JT's success message appearing in the DOM
  var fired = false;
  function fireSuccessEvent() {
    if (fired) return;
    fired = true;
    var sourceField = document.getElementById('jt-source');
    var projectField = document.getElementById('jt-project');
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'lead_form_submit',
      form_id: 'contact',
      lead_source: sourceField ? sourceField.value : '',
      project_type: projectField ? projectField.value : '',
      page_location: window.location.pathname
    });
  }

  // Strategy 1: MutationObserver watches for JT's success message
  var observer = new MutationObserver(function(mutations) {
    for (var i = 0; i < mutations.length; i++) {
      var added = mutations[i].addedNodes;
      for (var j = 0; j < added.length; j++) {
        var node = added[j];
        if (node.nodeType === 1) {
          var text = (node.textContent || '').toLowerCase();
          if (text.indexOf('thanks') !== -1 || text.indexOf("we'll be in touch") !== -1) {
            fireSuccessEvent();
            observer.disconnect();
            return;
          }
        }
      }
    }
  });
  observer.observe(form.parentElement, { childList: true, subtree: true });

  // Strategy 2: catch navigation to success URL as backup
  var successUrl = form.getAttribute('data-success-url');
  if (successUrl) {
    window.addEventListener('beforeunload', function() {
      if (form.dataset.submitted === 'true') {
        fireSuccessEvent();
      }
    });
  }

  autoSelectSource();
})();
</script>

{# ── Scoped: JT reset + honeypot only (visual styles in style.css) ── #}
<style>
  .hp-wrap {
    position: absolute;
    left: -9999px;
    top: -9999px;
    height: 0;
    width: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
  }
  .hwc-form.jtwf {
    max-width: none;
    box-shadow: none;
    background: transparent;
    font-family: var(--font-body, 'DM Sans', 'Helvetica Neue', sans-serif);
  }
  .hwc-form .mx-auto,
  .hwc-form .min-w-0,
  .hwc-form .max-w-sm,
  .hwc-form .rounded-sm,
  .hwc-form .shadow-sm,
  .hwc-form .bg-white,
  .hwc-form .p-4 {
    all: unset;
    display: block;
  }
</style>
