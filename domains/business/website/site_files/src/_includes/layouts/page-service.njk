---
layout: layouts/base.njk
---

<section class="hero{% if not hero_image %} hero-no-image{% endif %}">
  {% if hero_image %}
  <img class="hero__img" src="{{ hero_image }}" srcset="{{ hero_image | replace('.webp', '-800.webp') }} 800w, {{ hero_image }} 1600w" sizes="100vw" alt="{{ h1 | default(title) }}" fetchpriority="high" decoding="async" width="1600" height="1066">
  {% endif %}
  <div class="hero-overlay">
    <div class="container-wide">
      {% if hero_eyebrow %}<span class="hero-eyebrow">{{ hero_eyebrow }}</span>{% endif %}
      <h1>{{ h1 | default(title) }}</h1>
      {% if hero_subtitle %}<p class="hero-subtitle">{{ hero_subtitle }}</p>{% endif %}
      <hr class="long">
      <div class="hero-cta">
        <a href="{{ site.phoneLink }}" class="btn btn-primary">Call {{ site.phone }}</a>
        <a href="#contact-form" class="btn btn-outline-light">Request a Consultation</a>
      </div>
    </div>
  </div>
</section>

{% if stats %}
<section class="section section-tight">
  <div class="container-wide">
    <div class="stat-strip">
      {% for stat in stats %}
      <div class="stat-strip__item">
        <div class="stat-strip__num">{{ stat.value }}</div>
        <div class="stat-strip__label">{{ stat.label }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{% if photo_strip_images %}
<div class="photo-strip">
  {% for img in photo_strip_images %}
  <figure class="photo-strip__item">
    <img src="{{ img.src }}" alt="{{ img.alt }}" loading="lazy">
  </figure>
  {% endfor %}
</div>
{% endif %}

<article class="service-content section">
  <div class="container {% if content_wide %}container-wide{% else %}container-narrow{% endif %}">
    {{ content | safe }}
  </div>
</article>

{% if show_testimonials != false %}
{% set filter_service = service_tag %}
{% include "partials/section-testimonials.njk" %}
{% endif %}

{% if show_cta != false %}
{% include "partials/section-cta.njk" %}
{% endif %}

{% if show_form != false %}
{% include "partials/form-contact.njk" %}
{% endif %}
