---
layout: layouts/base.njk
---

{% if hero_image and hero_inline %}
<div class="page-header-image">
  <div class="container">
    <img src="{{ hero_image }}" alt="{{ h1 | default(title) }}" class="page-header-img">
    {% if hero_subtitle %}<p class="page-header-subtitle text-center">{{ hero_subtitle }}</p>{% endif %}
  </div>
</div>
{% elif hero_image %}
<section class="hero hero-short" style="background-image: url('{{ hero_image }}')">
  <div class="hero-overlay">
    <div class="container-wide">
      {% if hero_eyebrow %}<span class="hero-eyebrow">{{ hero_eyebrow }}</span>{% endif %}
      <h1>{{ h1 | default(title) }}</h1>
      {% if hero_subtitle %}<p class="hero-subtitle">{{ hero_subtitle }}</p>{% endif %}
      <hr class="long">
    </div>
  </div>
</section>
{% else %}
<header class="page-header">
  <div class="container-wide">
    {% if page_eyebrow %}<span class="eyebrow eyebrow-accent" style="margin-bottom:1.25rem;">{{ page_eyebrow }}</span>{% endif %}
    <h1>{{ h1 | default(title) }}</h1>
    <hr class="long">
    {% if hero_subtitle %}<p class="page-header-subtitle">{{ hero_subtitle }}</p>{% endif %}
  </div>
</header>
{% endif %}

<article class="section">
  <div class="container {% if content_wide %}container-wide{% else %}container-narrow{% endif %} page-content">
    {{ content | safe }}
  </div>
</article>

{% if show_services %}
{% include "partials/section-services-grid.njk" %}
{% endif %}

{% if show_testimonials %}
{% include "partials/section-testimonials.njk" %}
{% endif %}

{% if show_cta %}
{% include "partials/section-cta.njk" %}
{% endif %}

{% if show_form %}
{% include "partials/form-contact.njk" %}
{% endif %}
