---
layout: layouts/base.njk
---

<section class="hero{% if not hero_image %} hero-no-image{% endif %}" data-section="hero">
  {% if hero_image %}
  <img class="hero__img" src="{{ hero_image }}" srcset="{{ hero_image | replace('.webp', '-800.webp') }} 800w, {{ hero_image }} 1600w" sizes="100vw" alt="{{ h1 | default(title) }}" fetchpriority="high" decoding="async" width="1600" height="1066">
  {% endif %}
  <div class="hero-overlay">
    <div class="container-wide text-center">
      <span class="hero-eyebrow"><a href="/bathroom/remodeling/">BATHROOMS</a> · <a href="/services/">DECKS</a> · <a href="/services/">CARPENTRY</a> · <a href="/aging-in-place/">UNIVERSAL DESIGN</a></span>
      <h1>{{ h1 | default(title) }}</h1>
      {% if hero_subtitle %}<p class="hero-subtitle">{{ hero_subtitle }}</p>{% endif %}
      <hr class="long">
      <div class="hero-cta">
        <a href="{{ hero_cta_1_url | default('/contact/') }}" class="btn btn-primary">{{ hero_cta_1_text | default('Request a Consultation') }}</a>
        <a href="{{ hero_cta_2_url | default('/our-work/') }}" class="btn btn-secondary-solid">{{ hero_cta_2_text | default('See the Process') }}</a>
      </div>
    </div>
  </div>
</section>

{% if trust_items %}
<div class="trust-bar">
  <div class="container-wide trust-bar-inner">
    {% for item in trust_items %}
    <span>{{ item }}</span>
    {% endfor %}
  </div>
</div>
{% else %}
<div class="trust-bar">
  <div class="container-wide trust-bar-inner">
    <span>Licensed &amp; Insured</span>
    <span>5+ Years in Bozeman</span>
    <span>3D Design Previews</span>
    <span>Transparent Pricing</span>
  </div>
</div>
{% endif %}

{% if sections %}
  {% for section in sections %}
    {% if section == "intro" %}{% include "partials/section-intro.njk" %}
    {% elif section == "process" %}{% include "partials/section-process.njk" %}
    {% elif section == "services" %}{% include "partials/section-services-grid.njk" %}
    {% elif section == "locations" %}{% include "partials/section-locations.njk" %}
    {% elif section == "testimonials" %}{% include "partials/section-testimonials.njk" %}
    {% elif section == "reviews" %}{% set show_reviews_grid = true %}{% include "partials/section-testimonials.njk" %}{% set show_reviews_grid = false %}
    {% elif section == "portfolio" %}{% include "partials/section-portfolio-strip.njk" %}
    {% elif section == "portfolio-grid" %}{% include "partials/section-portfolio-grid.njk" %}
    {% elif section == "form-inline" %}{% include "partials/section-form-inline.njk" %}
    {% elif section == "cta" %}{% include "partials/section-cta.njk" %}
    {% elif section == "form" %}{% include "partials/form-contact.njk" %}
    {% endif %}
  {% endfor %}
{% else %}
  {{ content | safe }}
  {% if show_services != false %}{% include "partials/section-services-grid.njk" %}{% endif %}
  {% if show_testimonials != false %}{% include "partials/section-testimonials.njk" %}{% endif %}
  {% if show_cta != false %}{% include "partials/section-cta.njk" %}{% endif %}
  {% if show_form != false %}{% include "partials/form-contact.njk" %}{% endif %}
{% endif %}
