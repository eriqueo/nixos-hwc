---
layout: layouts/base.njk
---

<section class="hero" data-section="hero" {% if hero_image %}style="background-image: url('{{ hero_image }}')"{% endif %}>
  <div class="hero-overlay">
    <div class="container-wide text-center">
      <h1>{{ h1 | default(title) }}</h1>
      {% if hero_subtitle %}<p class="hero-subtitle">{{ hero_subtitle }}</p>{% endif %}
      <div class="hero-cta">
        <a href="{{ hero_cta_1_url | default('/contact/') }}" class="btn btn-primary">{{ hero_cta_1_text | default('Get Started') }}</a>
        <a href="{{ hero_cta_2_url | default('/our-work/') }}" class="btn btn-outline-light">{{ hero_cta_2_text | default('See Our Work') }}</a>
      </div>
    </div>
  </div>
</section>

{% if trust_items %}
<div class="trust-bar">
  <div class="container-wide trust-bar-inner">
    {% for item in trust_items %}
    <span>{{ item }}</span>
    {% endfor %}
  </div>
</div>
{% else %}
<div class="trust-bar">
  <div class="container-wide trust-bar-inner">
    <span>Licensed & Insured</span>
    <span>5+ Years in Bozeman</span>
    <span>3D Design Previews</span>
    <span>Transparent Pricing</span>
  </div>
</div>
{% endif %}

{% include "partials/section-portfolio-strip.njk" %}

{{ content | safe }}

{% if show_services != false %}
{% include "partials/section-services-grid.njk" %}
{% endif %}

{% if show_testimonials != false %}
{% include "partials/section-testimonials.njk" %}
{% endif %}

{% if show_cta != false %}
{% include "partials/section-cta.njk" %}
{% endif %}

{% if show_form != false %}
{% include "partials/form-contact.njk" %}
{% endif %}
