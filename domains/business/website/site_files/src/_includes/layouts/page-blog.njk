---
layout: layouts/base.njk
---

<article class="blog-post">
  <section class="hero{% if not featured_image %} hero-no-image{% endif %} hero-short" {% if featured_image %}style="background-image: url('{{ featured_image }}')"{% endif %}>
    <div class="hero-overlay">
      <div class="container-wide">
        <h1>{{ title }}</h1>
        <div class="blog-meta" style="color: rgba(255,255,255,0.7); margin-top: 0.5rem;">
          <time datetime="{{ date | dateISO }}">{{ date | dateReadable }}</time>
          &middot; {{ content | wordCount | divide(200) | round }} min read
        </div>
      </div>
    </div>
  </section>

  <div class="container container-narrow">

    <div class="blog-body">
      {{ content | safe }}
    </div>

    <section class="blog-cta">
      <h3>Planning a project in Bozeman?</h3>
      <p>We'd love to hear about it. Call <a href="{{ site.phoneLink }}">{{ site.phone }}</a> or <a href="#contact-form">request a consultation</a>.</p>
    </section>
  </div>

  <section class="blog-related section section-alt">
    <div class="container-wide">
      <h2>More from the Blog</h2>
      <div class="blog-grid">
        {% set related = collections.blog | rejectByUrl(page.url) | head(3) %}
        {% for post in related %}
        <a href="{{ post.url }}" class="card blog-card">
          {% if post.data.featured_image %}
          <img src="{{ post.data.featured_image }}" alt="{{ post.data.title }}" loading="lazy">
          {% endif %}
          <div class="blog-card-body">
            <h3>{{ post.data.title }}</h3>
          </div>
        </a>
        {% endfor %}
        {% if not related.length %}
        <p>More posts coming soon.</p>
        {% endif %}
      </div>
    </div>
  </section>
</article>

{% include "partials/form-contact.njk" %}
