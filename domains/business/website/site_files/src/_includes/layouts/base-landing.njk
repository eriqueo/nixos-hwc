<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ meta_description | default(site.description) }}">
  {% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ meta_description | default(site.description) }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  {% if og_image %}<meta property="og:image" content="{{ site.url }}{{ og_image }}">{% endif %}
  <meta property="og:site_name" content="{{ site.name }}">

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/img/brand/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/brand/apple-touch-icon.png">

  <!-- Preconnect for third-party resources -->
  <link rel="preconnect" href="https://chambermaster.blob.core.windows.net">
  <link rel="preconnect" href="https://bozemanchamber.chambermaster.com">

  <!-- Styles (inlined for performance) -->
  <style>{{ "" | inlineCSS | safe }}</style>

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-K3JD7X96');</script>
  <!-- End Google Tag Manager -->
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K3JD7X96"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

{# ── Minimal Landing Page Header — logo + phone only, no nav ── #}
<header class="site-header" id="site-header">
  <div class="container header-inner" style="justify-content: space-between;">
    <a class="logo" href="/">
      <img src="/img/brand/logo-header-v2.webp" alt="Heartwood Craft" class="logo-img">
    </a>
    <a href="{{ site.phoneLink }}" class="btn btn-get-started">Call {{ site.phone }}</a>
  </div>
</header>

<main>
  {{ content | safe }}
</main>

{# ── Minimal footer — no nav, just brand + phone ── #}
<footer class="site-footer" style="padding: 2rem 0; text-align: center;">
  <div class="container">
    <p style="color: var(--gray-400); font-size: 0.85rem; margin: 0;">
      Heartwood Craft · Bozeman, Montana · <a href="{{ site.phoneLink }}" style="color: var(--copper);">{{ site.phone }}</a>
      <br>Licensed & Insured · Serving Bozeman, Belgrade & Gallatin Gateway
    </p>
  </div>
</footer>

<script src="/js/main.js" defer></script>
<script src="/js/tracking.js" defer></script>
</body>
</html>
