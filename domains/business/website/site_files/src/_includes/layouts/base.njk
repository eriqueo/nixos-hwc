<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="{{ meta_description | default(site.description) }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }}">
  <meta property="og:description" content="{{ meta_description | default(site.description) }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="{{ og_type | default('website') }}">
  {% if og_image %}<meta property="og:image" content="{{ site.url }}{{ og_image }}">{% endif %}
  <meta property="og:site_name" content="{{ site.name }}">

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/img/brand/favicon-32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/img/brand/apple-touch-icon.png">

  <!-- Preconnect for third-party resources -->
  <link rel="preconnect" href="https://chambermaster.blob.core.windows.net">
  <link rel="preconnect" href="https://bozemanchamber.chambermaster.com">

  <!-- Preload hero image -->
  {% if hero_image %}<link rel="preload" as="image" href="{{ hero_image | replace('.webp', '-800.webp') }}" imagesrcset="{{ hero_image | replace('.webp', '-800.webp') }} 800w, {{ hero_image }} 1600w" imagesizes="100vw" fetchpriority="high">{% endif %}
  {% if featured_image %}<link rel="preload" as="image" href="{{ featured_image | replace('.webp', '-800.webp') }}" imagesrcset="{{ featured_image | replace('.webp', '-800.webp') }} 800w, {{ featured_image }} 1600w" imagesizes="100vw" fetchpriority="high">{% endif %}

  <!-- Styles (inlined for performance) -->
  <style>{{ "" | inlineCSS | safe }}</style>

  <!-- CMS Layout Overrides (from _data/theme.json) -->
  <style>
    :root {
      --font-body: {{ theme.fonts.body | safe }};
      --font-heading: {{ theme.fonts.heading | safe }};
      --max-width: {{ theme.containers.standard | safe }};
      --max-width-wide: {{ theme.containers.wide | safe }};
      --max-width-narrow: {{ theme.containers.narrow | safe }};
      --container-padding-x: {{ theme.containers.paddingX | safe }};
      --section-padding-y: {{ theme.sections.paddingY | safe }};
      --logo-height: {{ theme.header.logoHeight | safe }};
      --logo-height-mobile: {{ theme.header.logoHeightMobile | safe }};
      --hero-min-height: {{ theme.hero.minHeight | safe }};
      --hero-short-min-height: {{ theme.hero.shortMinHeight | safe }};
      --hero-h1-size: {{ theme.hero.h1FontSize | safe }};
      --hero-h1-max-width: {{ theme.hero.h1MaxWidth | safe }};
      --hero-subtitle-size: {{ theme.hero.subtitleFontSize | safe }};
      --hero-subtitle-max-width: {{ theme.hero.subtitleMaxWidth | safe }};
      --hero-overlay: {{ theme.hero.overlayGradient | safe }};
      --header-padding-x: {{ theme.header.headerPaddingX | safe }};
      --nav-font-size: {{ theme.header.navFontSize | safe }};
      --nav-font-weight: {{ theme.header.navFontWeight | safe }};
      --nav-padding-x: {{ theme.header.navPaddingX | safe }};
      --blog-card-img-height: {{ theme.blogCards.imageHeight | safe }};
      --blog-card-title-size: {{ theme.blogCards.titleFontSize | safe }};
      --blog-card-title-color: {{ theme.blogCards.titleColor | safe }};
      --blog-card-body-padding: {{ theme.blogCards.bodyPadding | safe }};
      --trust-bar-font-size: {{ theme.trustBar.fontSize | safe }};
    }
  </style>

  <!-- Structured Data -->
  {% if schema_type == "LocalBusiness" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "name": "{{ site.name }}",
    "description": "{{ site.description }}",
    "telephone": "{{ site.phone }}",
    "email": "{{ site.email }}",
    "url": "{{ site.url }}",
    "logo": "{{ site.url }}/img/brand/logo.webp",
    "image": "{{ site.url }}/img/hero/bozeman-remodeling.webp",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Bozeman",
      "addressRegion": "MT",
      "postalCode": "59715",
      "addressCountry": "US"
    },

    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 45.6770,
      "longitude": -111.0429
    },
    "areaServed": [
      {"@type": "City", "name": "Bozeman", "sameAs": "https://en.wikipedia.org/wiki/Bozeman,_Montana"},
      {"@type": "City", "name": "Belgrade", "sameAs": "https://en.wikipedia.org/wiki/Belgrade,_Montana"},
      {"@type": "City", "name": "Gallatin Gateway", "sameAs": "https://en.wikipedia.org/wiki/Gallatin_Gateway,_Montana"}
    ],
    "priceRange": "$$",
    "currenciesAccepted": "USD",
    "paymentAccepted": "Cash, Check, Credit Card",
    "knowsAbout": ["bathroom remodeling", "basement finishing", "deck building", "timber framing", "universal design", "aging in place"],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Remodeling Services",
      "itemListElement": [
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Bathroom Remodeling", "url": "{{ site.url }}/bathroom/remodeling/"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Basement Finishing", "url": "{{ site.url }}/basement/remodeling/"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Custom Deck Building", "url": "{{ site.url }}/remodeling/"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Universal Design & Aging in Place", "url": "{{ site.url }}/aging-in-place/"}}
      ]
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "ratingCount": "{{ testimonials | length }}",
      "reviewCount": "{{ testimonials | length }}"
    },
    "review": [
      {% for review in testimonials %}
      {
        "@type": "Review",
        "reviewRating": {"@type": "Rating", "ratingValue": "{{ review.rating }}", "bestRating": "5"},
        "author": {"@type": "Person", "name": "{{ review.name }}"},
        "reviewBody": "{{ review.text }}",
        "itemReviewed": {"@type": "HomeAndConstructionBusiness", "name": "{{ site.name }}"},
        "publisher": {"@type": "Organization", "name": "{{ review.source }}"}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ],
    "founder": {
      "@type": "Person",
      "name": "Eric",
      "jobTitle": "Owner & Licensed Contractor",
      "url": "{{ site.url }}/about/"
    },
    "sameAs": [
      "https://www.google.com/maps/place/Heartwood+Craft"
    ]
  }
  </script>
  {% elif schema_type == "Service" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "{{ title }}",
    "description": "{{ meta_description | default(site.description) }}",
    "url": "{{ site.url }}{{ page.url }}",
    "provider": {
      "@type": "HomeAndConstructionBusiness",
      "name": "{{ site.name }}",
      "telephone": "{{ site.phone }}",
      "url": "{{ site.url }}",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Bozeman",
        "addressRegion": "MT",
        "addressCountry": "US"
      }
    },
    "areaServed": [
      {"@type": "City", "name": "Bozeman"},
      {"@type": "City", "name": "Belgrade"},
      {"@type": "City", "name": "Gallatin Gateway"}
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "bestRating": "5",
      "ratingCount": "{{ testimonials | length }}",
      "reviewCount": "{{ testimonials | length }}"
    },
    "review": [
      {% for review in testimonials %}
      {
        "@type": "Review",
        "reviewRating": {"@type": "Rating", "ratingValue": "{{ review.rating }}", "bestRating": "5"},
        "author": {"@type": "Person", "name": "{{ review.name }}"},
        "reviewBody": "{{ review.text }}",
        "itemReviewed": {"@type": "Service", "name": "{{ title }}"},
        "publisher": {"@type": "Organization", "name": "{{ review.source }}"}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% elif schema_type == "BlogPosting" %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "{{ title }}",
    "description": "{{ meta_description | default(site.description) }}",
    "author": {
      "@type": "Person",
      "name": "Eric",
      "url": "{{ site.url }}/about/",
      "jobTitle": "Owner & Licensed Contractor"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ site.name }}",
      "logo": {"@type": "ImageObject", "url": "{{ site.url }}/img/brand/logo.webp"}
    },
    "datePublished": "{{ date | dateISO }}",
    "url": "{{ site.url }}{{ page.url }}"{% if featured_image %},
    "image": "{{ site.url }}{{ featured_image }}"{% endif %}{% if tags %},
    "keywords": "{{ tags | join(', ') }}"{% endif %},
    "mainEntityOfPage": {"@type": "WebPage", "@id": "{{ site.url }}{{ page.url }}"}
  }
  </script>
  {% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "{{ title }}",
    "description": "{{ meta_description | default(site.description) }}",
    "url": "{{ site.url }}{{ page.url }}"
  }
  </script>
  {% endif %}

  <!-- Breadcrumbs -->
  {% set crumbs = page.url | split("/") | compact %}
  {% if crumbs | length > 0 %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/"}
      ,{"@type": "ListItem", "position": 2, "name": "{{ title }}", "item": "{{ site.url }}{{ page.url }}"}
    ]
  }
  </script>
  {% endif %}
<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-K3JD7X96');</script>
<!-- End Google Tag Manager -->
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-K3JD7X96"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

{% include "partials/header.njk" %}

<main>
  {{ content | safe }}
</main>

{% include "partials/footer.njk" %}

<script src="/js/main.js" defer></script>
<script src="/js/tracking.js" defer></script>
</body>
</html>
