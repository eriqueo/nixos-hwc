{
  "fonts": {
    "body": "'DM Sans', 'Helvetica Neue', Arial, sans-serif",
    "heading": "'Playfair Display', Georgia, serif",
    "googleUrl": "https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Playfair+Display:wght@500;600;700&display=swap"
  },
  "header": {
    "logoHeight": "44px",
    "logoHeightMobile": "36px",
    "navFontSize": "0.8125rem",
    "navFontWeight": "500",
    "navPaddingX": "0",
    "headerPaddingX": "clamp(1.5rem, 1rem + 2vw, 3rem)",
    "showPhone": false
  },
  "hero": {
    "minHeight": "clamp(400px, 35vw + 100px, 650px)",
    "shortMinHeight": "clamp(300px, 25vw + 50px, 450px)",
    "h1FontSize": "clamp(2.5rem, 1.6rem + 2.5vw, 4rem)",
    "h1MaxWidth": "900px",
    "subtitleFontSize": "clamp(1.125rem, 1rem + 0.4vw, 1.375rem)",
    "subtitleMaxWidth": "750px",
    "overlayGradient": "linear-gradient(rgba(35,40,45,0.7), rgba(35,40,45,0.8))"
  },
  "containers": {
    "wide": "1500px",
    "standard": "1340px",
    "narrow": "800px",
    "paddingX": "clamp(1.5rem, 1rem + 1.5vw, 2.5rem)"
  },
  "sections": {
    "paddingY": "clamp(3rem, 2rem + 2.5vw, 5rem)"
  },
  "blogCards": {
    "imageHeight": "300px",
    "titleFontSize": "clamp(1.5rem, 1.2rem + 0.8vw, 1.75rem)",
    "titleColor": "#ebdbb2",
    "bodyPadding": "1.75rem 2rem 2rem"
  },
  "trustBar": {
    "fontSize": "1rem"
  }
}
