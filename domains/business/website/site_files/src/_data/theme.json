{
  "fonts": {
    "body": "'Source Serif 4', Georgia, serif",
    "heading": "'Playfair Display', Georgia, serif",
    "googleUrl": "https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400&display=swap"
  },
