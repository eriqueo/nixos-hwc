<style>
  /* ──────────────────────────────────────────────────────────────────────
     Heartwood Craft project summary report
     Ported from a Claude Design hi-fi mock to vanilla JS/CSS to match
     the existing site architecture.
     Uses site CSS vars (--copper, --fg1, --fg2, --fg3, --bg-dark, --bg-darker, --link)
     ─────────────────────────────────────────────────────────────────── */

  /* Shell */
  .hwc-rpt {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
    color: var(--fg1);
    font-family: var(--font-body);
  }
  @media (min-width: 720px) {
    .hwc-rpt { padding: 0 40px; }
  }

  /* Loading & error */
  .hwc-rpt-loading,
  .hwc-rpt-error {
    text-align: center;
    padding: 80px 20px;
    color: var(--fg3);
  }
  .hwc-rpt-loading .spinner {
    width: 32px; height: 32px;
    border: 3px solid var(--border-dark);
    border-top-color: var(--copper);
    border-radius: 50%;
    animation: hwc-spin 0.8s linear infinite;
    margin: 0 auto 16px;
  }
  @keyframes hwc-spin { to { transform: rotate(360deg); } }
  .hwc-rpt-error h2 {
    font-family: var(--font-heading);
    color: var(--fg1);
    margin: 0 0 8px;
  }

  /* Eyebrow */
  .hwc-eyebrow {
    font-family: var(--font-body);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 11px;
    font-weight: 500;
    color: var(--fg3);
  }
  .hwc-eyebrow.hwc-eyebrow--accent { color: var(--copper); }

  /* Rule */
  .hwc-rule {
    height: 2px;
    width: 64px;
    background: var(--copper);
    border: 0;
    margin: 0;
  }

  /* Photo placeholder — replaced with a real <img> when available */
  .hwc-photo {
    aspect-ratio: 16 / 9;
    background: #1a1c1d;
    background-image:
      repeating-linear-gradient(135deg, rgba(235,219,178,0.018) 0 12px, transparent 12px 24px);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 14px;
    box-sizing: border-box;
    border: 1px solid rgba(235,219,178,0.06);
  }
  .hwc-photo--card { aspect-ratio: 16 / 10; border: none; }
  .hwc-photo__label {
    font-family: var(--font-body);
    letter-spacing: 0.18em;
    color: #5a5d61;
    font-size: 9px;
    font-weight: 500;
    text-transform: uppercase;
  }
  .hwc-photo__img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }

  /* Header strip */
  .hwc-rpt-header {
    padding: 24px 0 12px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .hwc-rpt-header__logo { height: 22px; }
  .hwc-rpt-header__id {
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg3);
    font-weight: 500;
  }

  /* Section heading */
  .hwc-section { padding: 56px 0 0; }
  .hwc-section--hero { padding: 40px 0 8px; }
  .hwc-section--cta { padding: 64px 0 0; }
  .hwc-section--footer { padding: 56px 0 80px; }

  .hwc-sechead {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .hwc-sechead__num {
    font-size: 10px;
    letter-spacing: 0.18em;
    color: var(--copper);
    font-weight: 600;
    font-feature-settings: "tnum";
  }
  .hwc-sechead__title {
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: clamp(22px, 4.5vw, 28px);
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--fg1);
    margin: 0;
  }

  /* Hero */
  .hwc-hero__price {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(48px, 9vw, 88px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--fg1);
    margin: 20px 0 0;
    font-feature-settings: "lnum";
  }
  .hwc-hero__dash {
    color: var(--copper);
    font-style: italic;
    font-weight: 500;
    margin: 0 0.15em;
  }
  .hwc-hero__caption {
    font-size: 16px;
    line-height: 1.6;
    color: var(--fg2);
    margin: 20px 0 32px;
    max-width: 52ch;
  }

  /* Selections grid */
  .hwc-selections {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-top: 24px;
  }
  .hwc-selection {
    background: var(--bg-darker);
    border: 1px solid rgba(235,219,178,0.06);
    border-radius: 6px;
    padding: 12px 14px;
  }
  .hwc-selection__label {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg3);
    font-weight: 500;
    margin-bottom: 4px;
  }
  .hwc-selection__value {
    font-size: 14px;
    color: var(--fg1);
    font-weight: 500;
    line-height: 1.3;
  }

  /* Budget bar */
  .hwc-budget__bar {
    margin-top: 28px;
    display: flex;
    height: 56px;
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(235,219,178,0.08);
  }
  .hwc-budget__seg {
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 13px;
    border-right: 1px solid rgba(35,40,45,0.6);
  }
  .hwc-budget__seg:last-child { border-right: none; }
  .hwc-budget__legend {
    margin-top: 18px;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    row-gap: 10px;
    column-gap: 18px;
  }
  .hwc-budget__legend-row {
    display: grid;
    grid-template-columns: 14px 1fr auto;
    gap: 10px;
    align-items: baseline;
  }
  .hwc-budget__swatch {
    width: 10px; height: 10px;
    margin-top: 4px;
    border-radius: 2px;
  }
  .hwc-budget__legend-label {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--fg1);
    line-height: 1.3;
  }
  .hwc-budget__legend-range {
    font-size: 11.5px;
    color: var(--fg3);
    margin-top: 2px;
  }
  .hwc-budget__legend-pct {
    font-feature-settings: "tnum";
    font-size: 13px;
    color: var(--copper);
    font-weight: 600;
  }
  .hwc-budget__caption {
    margin-top: 28px;
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--fg3);
    font-style: italic;
    max-width: 60ch;
  }

  /* Recent work */
  .hwc-recent {
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 760px) {
    .hwc-recent { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  .hwc-recent__card {
    background: var(--bg-darker);
    border: 1px solid rgba(235,219,178,0.06);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .hwc-recent__body { padding: 20px 22px 22px; }
  .hwc-recent__loc {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .hwc-recent__title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--fg1);
    margin: 0 0 10px;
    letter-spacing: -0.005em;
  }
  .hwc-recent__desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg2);
    margin: 0 0 18px;
    max-width: 60ch;
  }
  .hwc-recent__total {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-top: 14px;
    border-top: 1px solid rgba(235,219,178,0.06);
    gap: 12px;
  }
  .hwc-recent__amount {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    color: var(--fg1);
    font-feature-settings: "lnum";
  }
  .hwc-recent__note {
    margin-top: 22px;
    font-size: 12.5px;
    color: var(--fg3);
    font-style: italic;
  }

  /* Timeline */
  .hwc-tl {
    list-style: none;
    padding: 0;
    margin: 32px 0 0;
    position: relative;
  }
  .hwc-tl__item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 18px;
    padding-bottom: 28px;
    position: relative;
  }
  .hwc-tl__item:last-child { padding-bottom: 0; }
  .hwc-tl__connector {
    position: absolute;
    left: 19px;
    top: 40px;
    bottom: 0;
    width: 2px;
    background: rgba(207,153,95,0.25);
  }
  .hwc-tl__node {
    width: 40px; height: 40px;
    border-radius: 999px;
    border: 1.5px solid var(--copper);
    color: var(--copper);
    background: var(--bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  .hwc-tl__week { color: var(--copper); margin-bottom: 4px; }
  .hwc-tl__title {
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 500;
    color: var(--fg1);
    line-height: 1.25;
    margin: 4px 0 8px;
    letter-spacing: -0.005em;
  }
  .hwc-tl__body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg2);
    max-width: 58ch;
  }

  /* CTA */
  .hwc-cta {
    background: var(--bg-darker);
    border: 1px solid rgba(235,219,178,0.08);
    border-radius: 8px;
    padding: clamp(28px, 6vw, 44px);
    position: relative;
    overflow: hidden;
  }
  .hwc-cta::before {
    content: "";
    position: absolute;
    top: 0; left: 0;
    height: 3px;
    width: 96px;
    background: var(--copper);
  }
  .hwc-cta__heading {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: clamp(28px, 5.5vw, 40px);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--fg1);
    margin: 14px 0 0;
    max-width: 20ch;
  }
  .hwc-cta__subhead {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--fg2);
    margin: 18px 0 28px;
    max-width: 50ch;
  }
  .hwc-cta__phone {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    text-decoration: none;
    background: var(--copper);
    color: var(--bg-dark);
    padding: 16px 22px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 22px;
    letter-spacing: -0.005em;
    font-feature-settings: "tnum";
    border: 0;
  }
  .hwc-cta__email {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
    font-size: 14px;
    color: var(--link);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .hwc-cta__email:hover { border-bottom-color: currentColor; }
  .hwc-cta__checklist-wrap {
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid rgba(235,219,178,0.08);
  }
  .hwc-cta__checklist {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
  }
  .hwc-cta__checklist li {
    display: grid;
    grid-template-columns: 20px 1fr;
    gap: 12px;
    align-items: flex-start;
    padding: 7px 0;
    color: var(--fg2);
    font-size: 14.5px;
    line-height: 1.5;
  }
  .hwc-cta__check {
    color: var(--copper);
    margin-top: 3px;
    display: flex;
  }

  /* Footer */
  .hwc-rpt-footer-text {
    margin-top: 24px;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg3);
    font-weight: 500;
  }
  .hwc-rpt-disclaimer {
    margin-top: 16px;
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--fg3);
    max-width: 60ch;
  }
  .hwc-rpt-print {
    margin-top: 24px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    color: var(--fg1);
    padding: 12px 20px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.04em;
    border: 1px solid var(--copper);
    cursor: pointer;
    font-family: inherit;
  }

  /* Print styles */
  @media print {
    .site-header, .site-footer, .site-nav, nav, header.site-header { display: none !important; }
    body { background: #fff !important; color: #23282d !important; }
    .hwc-rpt { max-width: 100% !important; padding: 0 !important; color: #23282d !important; }
    .hwc-rpt * { color: #23282d !important; }
    .hwc-photo { background: #ececec !important; }
    .hwc-rpt-print { display: none !important; }
    .hwc-section { padding: 32px 0 0 !important; break-inside: avoid; }
    .hwc-cta { background: #f7f5f0 !important; }
    .hwc-cta__phone { background: #cf995f !important; color: #fff !important; }
    .hwc-recent__card,
    .hwc-selection,
    .hwc-cta { background: #f7f5f0 !important; }
  }
</style>

<div class="hwc-rpt" id="hwc-report">
  <div class="hwc-rpt-loading">
    <div class="spinner"></div>
    <div>Loading your project summary...</div>
  </div>
</div>

<script>
