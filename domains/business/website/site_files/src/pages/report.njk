        { week: "Week 3",     icon: "list-checks", title: "Stairs & punch list",    body: "Stair run rebuilt, finishing touches, walk-through." }
      ],
      partial_rebuild: [
        { week: "Days 1–2",   icon: "pickaxe",     title: "Selective demo",         body: "Decking and rails come off. Existing frame stays — we inspect every joist and replace anything questionable." },
        { week: "Days 3–4",   icon: "square",      title: "Frame remediation",      body: "Replace any compromised joists, re-flash the ledger if needed, sister beams where structural." },
        { week: "Days 5–7",   icon: "grid",        title: "Decking & railings",     body: "New boards, new rails. Materials and lead times drive the pace here." },
        { week: "Day 8",      icon: "list-checks", title: "Walkthrough",            body: "Walk-through with you. Stairs and skirting if those are part of the scope." }
      ],
      repair_refresh: [
        { week: "Day 1",      icon: "pickaxe",     title: "Assess & quote",         body: "We come out, look at the actual condition, and confirm the scope. Sometimes the fix is smaller than expected, sometimes larger." },
        { week: "Days 2–3",   icon: "wrench",      title: "Targeted repair",        body: "Replace what's failed — joists, decking boards, stair stringers, rail sections. Stain or seal as part of the same visit." },
        { week: "Days 3–4",   icon: "list-checks", title: "Walk & finish",          body: "Final walk-through. We document what we touched so you have a clear record." }
      ]
    }
  };

  // CTA copy — brand-compliant. No "free", no time-bound promises.
  var CTA_COPY = {
    bathroom: {
      heading: "Eric will be in touch.",
      subhead: "Your project summary is on its way to {email}. Eric will review the details and call to walk through the numbers in person — no script, no sales pitch.",
      checklist: [
        "Photos of the current bathroom — wide shots and close-ups of anything you want to keep or change.",
        "Your must-haves vs. nice-to-haves. The first list shapes the budget; the second shapes the trade-offs.",
        "A budget ceiling you're comfortable saying out loud. It saves us both time and lets the conversation be honest."
      ]
    },
    deck: {
      heading: "Eric will be in touch.",
      subhead: "Your project summary is on its way to {email}. Eric will review the details and call to walk through the numbers — and the deck-season build window — in person.",
      checklist: [
        "Photos of where the deck will sit — the house wall, ground conditions, and any existing deck or patio.",
        "Your must-haves vs. nice-to-haves. Cable rail, lighting, and skirting are common trade-offs to budget around.",
        "A budget ceiling you're comfortable saying out loud. It saves us both time and lets the conversation be honest."
      ]
    }
  };

  // Lucide-style icons (1.75 stroke, currentColor). Same set as the mock.
  var ICONS = {
    pickaxe:       '<path d="M14 12 9 7l-1 1 5 5"/><path d="M22 2c-3 1-5 3-7 6l4 4c3-2 5-4 6-7"/><path d="m13 13-9 9"/>',
    wrench:        '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.8-3.8a6 6 0 0 1-7.9 7.9l-6.9 6.9a2.1 2.1 0 1 1-3-3l6.9-6.9a6 6 0 0 1 7.9-7.9z"/>',
    droplets:      '<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>',
    square:        '<rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18"/><path d="M9 3v18"/>',
    grid:          '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>',
    'list-checks': '<path d="m3 17 2 2 4-4"/><path d="m3 7 2 2 4-4"/><path d="M13 6h8"/><path d="M13 12h8"/><path d="M13 18h8"/>',
    phone:         '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>',
    mail:          '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>',
    printer:       '<polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/>',
    check:         '<polyline points="20 6 9 17 4 12"/>',
    'map-pin':     '<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>'
  };

  function icon(name, size) {
    size = size || 20;
    return '<svg width="' + size + '" height="' + size + '" viewBox="0 0 24 24" fill="none" ' +
      'stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
      (ICONS[name] || '') + '</svg>';
  }

  function esc(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  }

  function humanize(s) {
    return String(s || '').replace(/_/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  }

  // ────────────────────────────────────────────────────────────────────────
  // FETCH AND RENDER
  // ────────────────────────────────────────────────────────────────────────
  var params = new URLSearchParams(window.location.search);
  var reportId = params.get('id');

  if (!reportId) {
    showError("No report ID found. If you just completed a calculator, check your email for the correct link.");
    return;
  }

  fetch("https://hwc.ocelot-wahoo.ts.net/webhook/report-data?id=" + encodeURIComponent(reportId))
    .then(function(res) {
      if (!res.ok) throw new Error("Not found");
      return res.json();
    })
    .then(function(data) { render(data); })
    .catch(function() {
      showError("Couldn't load this report. The link may have expired or been entered incorrectly. Call 406-551-5061 and I'll walk you through the numbers.");
    });

  function showError(msg) {
    document.getElementById('hwc-report').innerHTML =
      '<div class="hwc-rpt-error">' +
        '<h2>Report not found</h2>' +
        '<p>' + esc(msg) + '</p>' +
      '</div>';
  }

  function render(d) {
    var calc = d.calculator || 'bathroom';
    var calcLabel = CALC_LABELS[calc] || calc;
    var state = d.project_state || {};
    var name = d.contact_name || '';
    var firstName = name.split(' ')[0] || 'you';
    var email = d.contact_email || 'you';
    var lo = Number(d.estimate_low || 0);
    var hi = Number(d.estimate_high || 0);
    var shortcode = (d.report_id || reportId || '').toUpperCase();

    var ctaCopy = CTA_COPY[calc] || CTA_COPY.bathroom;
    var budget = BUDGET[calc] || BUDGET.bathroom;
    var recent = RECENT[calc] || RECENT.bathroom;

    // Pick the timeline matching project_type, with a sensible fallback.
    var timelineSet = TIMELINES[calc] || TIMELINES.bathroom;
    var timeline = timelineSet[state.project_type] ||
                   (calc === 'deck' ? timelineSet.new_build : timelineSet.full_gut);

    document.getElementById('hwc-report').innerHTML =
      headerStrip(shortcode) +
      hero(calcLabel, firstName, lo, hi) +
      selections(state, calc) +
      budgetSection(budget, lo, hi) +
      recentWork(recent) +
      timelineSection(timeline) +
      cta(ctaCopy, email) +
      footer();

    document.title = firstName + "'s " + (calc === 'deck' ? 'Deck' : 'Bathroom') + ' Summary | Heartwood Craft';
  }

  // ────────────────────────────────────────────────────────────────────────
  // RENDER FUNCTIONS
  // ────────────────────────────────────────────────────────────────────────

  function headerStrip(shortcode) {
    return '<header class="hwc-rpt-header">' +
      '<img class="hwc-rpt-header__logo" src="/img/logo-wordmark-cream.svg" alt="Heartwood Craft" onerror="this.style.display=\'none\'" />' +
      '<div class="hwc-rpt-header__id">Project summary' + (shortcode ? ' · ' + esc(shortcode) : '') + '</div>' +
    '</header>';
  }

  function hero(calcLabel, firstName, lo, hi) {
    return '<section class="hwc-section hwc-section--hero">' +
      '<div class="hwc-eyebrow hwc-eyebrow--accent">Your ' + esc(calcLabel) + ' estimate · prepared for ' + esc(firstName) + '</div>' +
      '<h1 class="hwc-hero__price">' +
        '<span style="white-space:nowrap">$' + lo.toLocaleString() + '</span>' +
        '<span class="hwc-hero__dash">–</span>' +
        '<span style="white-space:nowrap">$' + hi.toLocaleString() + '</span>' +
      '</h1>' +
      '<hr class="hwc-rule" style="margin-top:28px" />' +
      '<p class="hwc-hero__caption">Based on real Heartwood Craft projects in the Gallatin Valley — not national averages.</p>' +
      '<div class="hwc-photo">' +
        '<div class="hwc-photo__label">Recent Heartwood Craft ' + esc(calcLabel) + '</div>' +
      '</div>' +
    '</section>';
  }

  function selections(state, calc) {
    // Display order matches what the customer answered in the calculator.
    var stepOrder = calc === 'deck'
      ? ['project_type','deck_size','deck_height','material','railing']
      : ['project_type','bathroom_size','shower_tub','tile_level','fixtures'];

    var items = [];
    stepOrder.forEach(function(key) {
      var val = state[key];
      if (!val) return;
      items.push({
        label: STEP_LABELS[key] || humanize(key),
        value: humanize(val)
      });
    });
    // Features become a single chip with a comma-separated list, if any.
    var features = state.features || [];
    if (features.length) {
      items.push({
        label: 'Features',
        value: features.map(humanize).join(' · ')
      });
    }
    if (state.timeline) {
      items.push({ label: 'Timeline', value: humanize(state.timeline) });
    }

    if (!items.length) return '';

    var html = '<section class="hwc-section">' +
      sectionHead('01', 'Your selections') +
      '<div class="hwc-selections">';
    items.forEach(function(it) {
      html += '<div class="hwc-selection">' +
        '<div class="hwc-selection__label">' + esc(it.label) + '</div>' +
        '<div class="hwc-selection__value">' + esc(it.value) + '</div>' +
      '</div>';
    });
    html += '</div></section>';
    return html;
  }

  function budgetSection(segments, lo, hi) {
    var html = '<section class="hwc-section">' +
      sectionHead('02', 'Where the budget goes') +
      '<div class="hwc-budget__bar">';

    segments.forEach(function(s, i) {
      html += '<div class="hwc-budget__seg" style="' +
        'flex:' + s.pct + ';' +
        'background:' + s.color + ';' +
        'color:' + s.fg + ';' +
        (i === segments.length - 1 ? 'border-right:none;' : '') +
      '">' + (s.pct >= 8 ? s.pct + '%' : '') + '</div>';
    });
    html += '</div><div class="hwc-budget__legend">';
    segments.forEach(function(s) {
      var segLo = Math.round(lo * s.pct / 100 / 100) * 100;
      var segHi = Math.round(hi * s.pct / 100 / 100) * 100;
      html += '<div class="hwc-budget__legend-row">' +
        '<div class="hwc-budget__swatch" style="background:' + s.color + '"></div>' +
        '<div>' +
          '<div class="hwc-budget__legend-label">' + esc(s.label) + '</div>' +
          '<div class="hwc-budget__legend-range">$' + segLo.toLocaleString() + '–$' + segHi.toLocaleString() + '</div>' +
        '</div>' +
        '<div class="hwc-budget__legend-pct">' + s.pct + '%</div>' +
      '</div>';
    });
    html += '</div>' +
      '<p class="hwc-budget__caption">Illustrative — actual breakdown depends on selections, site conditions, and final material picks. We walk through every line item together at the site visit.</p>' +
    '</section>';
    return html;
  }

  function recentWork(projects) {
    var html = '<section class="hwc-section">' +
      sectionHead('03', 'Recent work like yours') +
      '<div class="hwc-recent">';
    projects.forEach(function(p) {
      html += '<article class="hwc-recent__card">' +
        '<div class="hwc-photo hwc-photo--card">' +
          '<div class="hwc-photo__label">' + esc(p.photoLabel) + '</div>' +
        '</div>' +
        '<div class="hwc-recent__body">' +
          '<div class="hwc-recent__loc">' + icon('map-pin', 14) +
            '<span class="hwc-eyebrow">' + esc(p.location) + '</span>' +
          '</div>' +
          '<h3 class="hwc-recent__title">' + esc(p.title) + '</h3>' +
          '<p class="hwc-recent__desc">' + esc(p.desc) + '</p>' +
          '<div class="hwc-recent__total">' +
            '<span class="hwc-eyebrow">Project total</span>' +
            '<div class="hwc-recent__amount">$' + Number(p.total).toLocaleString() + '</div>' +
          '</div>' +
        '</div>' +
      '</article>';
    });
    html += '</div>' +
      '<p class="hwc-recent__note">These are real Heartwood Craft jobs, completed in the Gallatin Valley.</p>' +
    '</section>';
    return html;
  }

  function timelineSection(steps) {
    var html = '<section class="hwc-section">' +
      sectionHead('04', 'What a project like yours typically looks like') +
      '<ol class="hwc-tl">';
    steps.forEach(function(step, i) {
      html += '<li class="hwc-tl__item">' +
        (i < steps.length - 1 ? '<div class="hwc-tl__connector"></div>' : '') +
        '<div class="hwc-tl__node">' + icon(step.icon, 18) + '</div>' +
        '<div>' +
          '<div class="hwc-eyebrow hwc-tl__week">' + esc(step.week) + '</div>' +
          '<div class="hwc-tl__title">' + esc(step.title) + '</div>' +
          '<div class="hwc-tl__body">' + esc(step.body) + '</div>' +
        '</div>' +
      '</li>';
    });
    html += '</ol></section>';
    return html;
  }

  function cta(ctaCopy, email) {
    var subhead = ctaCopy.subhead.replace('{email}', '<strong>' + esc(email) + '</strong>');
    var html = '<section class="hwc-section hwc-section--cta">' +
      '<div class="hwc-cta">' +
        '<div class="hwc-eyebrow">Next step</div>' +
        '<h2 class="hwc-cta__heading">' + esc(ctaCopy.heading) + '</h2>' +
        '<p class="hwc-cta__subhead">' + subhead + '</p>' +
        '<a class="hwc-cta__phone" href="tel:4065515061">' + icon('phone', 22) + '406-551-5061</a>' +
        '<div><a class="hwc-cta__email" href="mailto:eric@iheartwoodcraft.com">' + icon('mail', 14) + 'eric@iheartwoodcraft.com</a></div>' +
        '<div class="hwc-cta__checklist-wrap">' +
          '<div class="hwc-eyebrow">What to have ready when we talk</div>' +
          '<ul class="hwc-cta__checklist">';
    ctaCopy.checklist.forEach(function(c) {
      html += '<li><span class="hwc-cta__check">' + icon('check', 16) + '</span><span>' + esc(c) + '</span></li>';
    });
    html += '</ul></div></div></section>';
    return html;
  }

  function footer() {
    return '<footer class="hwc-section hwc-section--footer">' +
      '<hr class="hwc-rule" />' +
      '<div class="hwc-rpt-footer-text">Heartwood Craft · Bozeman, Montana</div>' +
      '<p class="hwc-rpt-disclaimer">' +
        'Estimates are based on actual project data from Bozeman remodels. Final pricing is established after a site visit and detailed scope discussion.' +
      '</p>' +
      '<button class="hwc-rpt-print" onclick="window.print()">' + icon('printer', 16) + 'Print this report</button>' +
    '</footer>';
  }

  function sectionHead(num, title) {
    return '<div class="hwc-sechead">' +
      '<span class="hwc-sechead__num">' + esc(num) + '</span>' +
      '<h2 class="hwc-sechead__title">' + esc(title) + '</h2>' +
    '</div>';
  }
})();
</script>
