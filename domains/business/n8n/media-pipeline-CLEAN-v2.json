{
  "name": "Media Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "media-pipeline",
        "options": {}
      },
      "id": "trigger-webhook",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [-1200, 0],
      "webhookId": "media-pipeline"
    },
    {
      "parameters": {
        "jsCode": "// Normalize incoming *arr webhook into a standard shape\nconst body = $input.item.json.body || $input.item.json || {};\n\n// Detect source from query param or body\nconst query = $input.item.json.query || {};\nlet source = (query.source || body.source || '').toString().toLowerCase();\n\n// Auto-detect from payload shape if source param missing\nif (!source) {\n  if (body.movie || body.remoteMovie) source = 'radarr';\n  else if (body.series || body.episodes) source = 'sonarr';\n  else source = 'unknown';\n}\n\nlet title = '';\nlet path = '';\nlet quality = '';\nlet eventType = body.eventType || 'Download';\nlet searchTitle = '';\nlet itemType = '';\n\nif (source === 'radarr') {\n  title = body?.movie?.title || body?.remoteMovie?.title || '';\n  path = body?.movieFile?.path || body?.movie?.path || '';\n  quality = body?.movieFile?.quality?.quality?.name || '';\n  searchTitle = title;\n  itemType = 'Movie';\n} else if (source === 'sonarr') {\n  const seriesTitle = body?.series?.title || '';\n  const ep = (body?.episodes && body.episodes[0]) || {};\n  const epNum = ep.seasonNumber != null\n    ? `S${String(ep.seasonNumber).padStart(2,'0')}E${String(ep.episodeNumber).padStart(2,'0')}`\n    : '';\n  title = `${seriesTitle} ${epNum}`.trim();\n  path = body?.episodeFile?.path || '';\n  quality = body?.episodeFile?.quality?.quality?.name || '';\n  searchTitle = seriesTitle;\n  itemType = 'Series';\n} else {\n  title = body?.title || 'Unknown';\n  path = body?.path || '';\n  quality = body?.quality || '';\n  searchTitle = title;\n  itemType = 'Movie';\n}\n\nreturn {\n  json: {\n    mediaType: source,\n    title,\n    searchTitle,\n    itemType,\n    path,\n    quality,\n    eventType\n  }\n};"
      },
      "id": "parse-event",
      "name": "Parse Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-960, 0]
    },
    {
      "parameters": {
        "amount": 30,
        "unit": "seconds"
      },
