    {
      "parameters": {
        "jsCode": "// Check if item was found in Jellyfin\nconst result = $input.item.json;\nconst items = result.Items || [];\nconst found = items.length > 0;\nconst prev = $('Parse Event').first().json;\n\nreturn {\n  json: {\n    ...prev,\n    indexed: found,\n    jellyfinItemCount: items.length\n  }\n};"
      },
      "id": "check-indexed",
      "name": "Check Index Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, -40]
    },
    {
      "parameters": {
        "jsCode": "// Generate notification\nconst { mediaType, title, quality, path, indexed } = $json;\nconst emoji = { radarr: '🎬', sonarr: '📺' }[mediaType] || '📦';\nconst mediaLabel = { radarr: 'Movie', sonarr: 'TV Show' }[mediaType] || 'Media';\nconst indexStatus = indexed ? '✅ Indexed in Jellyfin' : '⚠️ Not yet indexed — may need manual refresh';\n\nreturn {\n  json: {\n    title: `${emoji} ${title}`,\n    message: `New ${mediaLabel} available\\n\\nQuality: ${quality}\\nPath: ${path}\\n\\n${indexStatus}`,\n    topic: 'hwc-media',\n    priority: 2,\n    tags: `${mediaType},media,new`\n  }\n};"
      },
      "id": "gen-notification",
      "name": "Generate Notification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, -40]
