    {
      "parameters": {
        "jsCode": "// Find the movies library\nconst data = $input.item.json;\nconst items = data.Items || (Array.isArray(data) ? data : []);\n\nconst lib = items.find(l => l.CollectionType && l.CollectionType.toLowerCase() === 'movies')\n  || items[0]\n  || null;\n\nconst prev = $('Parse Event').first().json;\n\nreturn {\n  json: {\n    ...prev,\n    libraryId: lib ? lib.Id : null,\n    libraryName: lib ? lib.Name : null\n  }\n};"
      },
