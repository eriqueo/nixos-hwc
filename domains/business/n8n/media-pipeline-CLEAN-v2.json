        "jsCode": "// Error notification\nconst err = $input.item.json || {};\nreturn {\n  json: {\n    title: '⚠️ Media Pipeline Error',\n    message: `Error in media pipeline workflow.\\n\\nError: ${JSON.stringify(err).substring(0, 500)}\\n\\nCheck n8n logs.`,\n    topic: 'hwc-alerts',\n    priority: 4,\n    tags: 'media,error,pipeline'\n  }\n};"
      },
