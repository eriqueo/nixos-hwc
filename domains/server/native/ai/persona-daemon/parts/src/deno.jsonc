{
  "imports": {
    "zod": "npm:zod@3.23.8",
    "@db/sqlite": "jsr:@db/sqlite@0.11.1",
    "@std/uuid": "jsr:@std/uuid@1.0.4"
  },
  "tasks": {
    "dev": "deno run --watch --allow-all main.ts",
    "test": "deno test --allow-all"
  },
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitOverride": true
  }
}
