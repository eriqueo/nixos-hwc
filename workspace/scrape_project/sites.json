{
  "global_config": {
    "default_scrolls": 10,
    "default_scroll_delay": 3.0,
    "default_timeout": 15000,
    "headless": false
  },
  "sites": [
    {
      "name": "Facebook Group",
      "url_pattern": "https://www.facebook.com/groups/",
      "login_required": true,
      "post_container_selector": "div[role=\"article\"][data-pagelet^=\"GroupFeed\"]",
      "scraper_config": {
        "scroll_delay": 5.0,
        "timeout": 30000,
        "rate_limit_rpm": 10
      },
      "scrapers": {
        "author": {
          "selector": "h3 a, strong a, a[role=\"link\"][aria-label]",
          "type": "text"
        },
        "date": {
          "selector": "a[aria-label][href*=\"/posts/\"] > span, a[aria-label][href*=\"/videos/\"] > span",
          "type": "text"
        },
        "text": {
          "selector": "div[data-ad-preview=\"message\"], div[style=\"text-align: start;\"]",
          "type": "text"
        },
        "reactions": {
          "selector": "[aria-label*=\"reaction\"]",
          "type": "text"
        },
        "url": {
          "selector": "a[aria-label][href*=\"/posts/\"], a[aria-label][href*=\"/videos/\"]",
          "type": "href"
        },
        "comments_container_selector": {
          "selector": "div[data-testid=\"UFI2Comment/root_depth_0\"]",
          "type": "text"
        },
        "comment_author": {
          "selector": "a[data-hovercard-prefer-more-content-show=\"1\"]",
          "type": "text"
        },
        "comment_text": {
          "selector": "div[data-ad-preview=\"message\"]",
          "type": "text"
        }
      }
    },
    {
      "name": "Reddit",
      "url_pattern": "https://www.reddit.com/r/",
      "login_required": false,
      "post_container_selector": "shreddit-post",
      "scraper_config": {
        "scroll_delay": 2.0,
        "rate_limit_rpm": 30
      },
      "attribute_map": {
        "author": "author",
        "text": "post-title",
        "url": "permalink",
        "reactions": "score",
        "date": "created-timestamp"
      },
      "scrapers": {}
    },
    {
      "name": "Nextdoor",
      "url_pattern": "https://nextdoor.com/",
      "login_required": true,
      "post_container_selector": "article[data-testid=\"post-content\"]",
      "scraper_config": {
        "scroll_delay": 4.0,
        "rate_limit_rpm": 15
      },
      "scrapers": {
        "author": {
          "selector": "a[data-testid=\"post-author-name-link\"]",
          "type": "text"
        },
        "date": {
          "selector": "a.post-byline__timestamp",
          "type": "text"
        },
        "text": {
          "selector": "div.post-text-content, p[data-testid=\"post-text-content\"]",
          "type": "text"
        },
        "reactions": {
          "selector": "[data-testid=\"post-ufi-thank-button\"] > span",
          "type": "text"
        },
        "comments_container_selector": {
          "selector": "li.comment-item",
          "type": "text"
        },
        "comment_author": {
          "selector": "a.comment-author__name",
          "type": "text"
        },
        "comment_text": {
          "selector": "div.comment-text",
          "type": "text"
        }
      }
    }
  ]
}
