# Heartwood MCP Server Environment Variables
# Copy to .env and fill in values (or set via systemd EnvironmentFile)

# JobTread PAVE API
JT_GRANT_KEY=your-grant-key-here
JT_ORG_ID=22Nm3uFevXMb
JT_USER_ID=22Nm3uFeRB7s
JT_API_URL=https://api.jobtread.com/pave

# Paperless-ngx (Phase 2)
# PAPERLESS_URL=http://localhost:8000
# PAPERLESS_TOKEN=your-paperless-token

# Firefly III (Phase 2)
# FIREFLY_URL=http://localhost:8080
# FIREFLY_TOKEN=your-firefly-token

# Logging
LOG_LEVEL=info

# Transport (stdio or sse)
TRANSPORT=stdio

# SSE transport settings (when TRANSPORT=sse)
# SSE_HOST=127.0.0.1
# SSE_PORT=6100
