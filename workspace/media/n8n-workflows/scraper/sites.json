{
  "facebook_group": {
    "name": "Facebook",
    "url_pattern": "facebook\\.com/groups/",
    "requires_auth": true,
    "selectors": {
      "post_container": "[data-pagelet*='FeedUnit'], [role='article']",
      "fields": {
        "author": "h2 a[role='link'] span, strong a span",
        "date": "a[href*='/posts/'] span, span[id*='jsc'] a",
        "text": "[data-ad-preview='message'], [data-ad-comet-preview='message']",
        "reactions": "[aria-label*='reaction'], [aria-label*='like']",
        "comments_count": "a[href*='comment'] span"
      }
    }
  },
  "reddit": {
    "name": "Reddit",
    "url_pattern": "reddit\\.com/r/",
    "requires_auth": false,
    "selectors": {
      "post_container": "shreddit-post, [data-testid='post-container'], .Post",
      "fields": {
        "author": "[data-testid='post_author_link'], a[href*='/user/']",
        "date": "time, [data-testid='post-timestamp']",
        "text": "[data-testid='post-content'] p, .RichTextJSON-root p, [slot='text-body']",
        "reactions": "[data-testid='vote-count'], shreddit-post faceplate-number",
        "comments_count": "[data-testid='post-comment-count'], a[href*='/comments/']"
      }
    }
  },
  "nextdoor": {
    "name": "Nextdoor",
    "url_pattern": "nextdoor\\.com",
    "requires_auth": true,
    "selectors": {
      "post_container": "[data-testid='post-card'], article[class*='post']",
      "fields": {
        "author": "[data-testid='author-name'], [class*='author'] a",
        "date": "time, [class*='timestamp']",
        "text": "[data-testid='post-body'], [class*='post-content'] p",
        "reactions": "[data-testid='reaction-count'], [class*='reaction'] span",
        "comments_count": "[data-testid='comment-count'], [class*='comment'] span"
      }
    }
  }
}
