<section class="section section-cta section-alt animate-in" data-section="cta">
  <div class="container container-narrow text-center">
    <h2>{{ cta_heading if cta_heading else "Ready to Talk About Your Project?" }}</h2>
    <p>{{ cta_text if cta_text else "Call for a free consultation or fill out the form below. No pressure, no commitment — just a conversation about what's possible." }}</p>
    <div class="cta-buttons">
      <a href="{{ site.phoneLink }}" class="btn btn-primary">Call {{ site.phone }}</a>
      <a href="#contact-form" class="btn btn-outline">Request an Estimate</a>
    </div>
  </div>
</section>
