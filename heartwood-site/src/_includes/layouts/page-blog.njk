---
layout: layouts/base.njk
---

<article class="blog-post">
  {% if featured_image %}
  <div class="blog-hero">
    <img src="{{ featured_image }}" alt="{{ title }}" loading="eager">
  </div>
  {% endif %}

  <div class="container container-narrow">
    <header class="blog-header">
      <h1>{{ title }}</h1>
      <div class="blog-meta">
        <time datetime="{{ date | dateISO }}">{{ date | dateReadable }}</time>
        &middot; {{ content | wordCount | divide(200) | round }} min read
      </div>
    </header>

    <div class="blog-body">
      {{ content | safe }}
    </div>

    <section class="blog-cta">
      <h3>Planning a project in Bozeman?</h3>
      <p>We'd love to hear about it. Call <a href="{{ site.phoneLink }}">{{ site.phone }}</a> or <a href="#contact-form">request a free estimate</a>.</p>
    </section>
  </div>

  <section class="blog-related section section-alt">
    <div class="container">
      <h2>More from the Blog</h2>
      <div class="blog-grid">
        {% set related = collections.blog | rejectByUrl(page.url) | head(3) %}
        {% for post in related %}
        <a href="{{ post.url }}" class="card blog-card">
          {% if post.data.featured_image %}
          <img src="{{ post.data.featured_image }}" alt="{{ post.data.title }}" loading="lazy">
          {% endif %}
          <div class="blog-card-body">
            <h3>{{ post.data.title }}</h3>
          </div>
        </a>
        {% endfor %}
        {% if not related.length %}
        <p>More posts coming soon.</p>
        {% endif %}
      </div>
    </div>
  </section>
</article>

{% include "partials/form-contact.njk" %}
