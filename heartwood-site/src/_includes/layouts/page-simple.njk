---
layout: layouts/base.njk
---

{% if hero_image %}
<section class="hero hero-short" style="background-image: url('{{ hero_image }}')">
  <div class="hero-overlay">
    <div class="container">
      <h1>{{ h1 | default(title) }}</h1>
    </div>
  </div>
</section>
{% else %}
<section class="page-header">
  <div class="container">
    <h1>{{ h1 | default(title) }}</h1>
  </div>
</section>
{% endif %}

<div class="container container-narrow page-content section">
  {{ content | safe }}
</div>

{% if show_form != false %}
{% include "partials/form-contact.njk" %}
{% endif %}
